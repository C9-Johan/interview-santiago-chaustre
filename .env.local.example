# Secrets + per-developer overrides. Copy to .env.local (which is
# gitignored) and fill in. mise will load this automatically on any
# `mise run` / `mise exec`.
#
# Non-secret defaults live in .mise.toml [env]; only override what you
# actually want different.

# Required for any path that actually hits the LLM: make e2e, make eval,
# the tester UI, the full dev stack. Get a key from https://platform.deepseek.com
# or https://platform.openai.com (in which case also set LLM_BASE_URL).
LLM_API_KEY=

# Uncomment to target OpenAI instead of the DeepSeek default.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_CLASSIFIER=gpt-4o-mini
# LLM_MODEL_GENERATOR=gpt-4o-mini

# Per-developer overrides you may want in dev:
# ADMIN_TOKEN=<your-own-token>
# GUESTY_WEBHOOK_SECRET=<pre-shared-secret-with-the-tester>
# LLM_BUDGET_DAILY_USD=5.0
